# ── Environment Configuration ───────────────────────────────────────────────
NODE_ENV=development

# --- FRONTEND CONFIGURATION (NEXT_PUBLIC_ prefix for browser-side access) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_URL="http://localhost:3000"

# --- ANALYTICS (Optional) ---
NEXT_PUBLIC_GA_ID=""

# --- MIDTRANS PAYMENT GATEWAY ---
# Client key untuk Snap JS (sandbox)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""

# --- SITE CONFIGURATION ---
# Uncomment untuk override site default (default: "pusat")
# NEXT_PUBLIC_SITE_ID="pusat"

# ============================================================
# Production (Vercel):
#   Set di Vercel Dashboard → Project → Settings → Environment Variables
#   NEXT_PUBLIC_API_URL="https://api.beritakarya.co"
#   NEXT_PUBLIC_URL="https://beritakarya.co"
#   NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
#   NEXT_PUBLIC_SITE_ID="pusat"
#
# Backend API di self-hosted CT 102 — lihat apps/api/.env.example.selfhosted
# ============================================================
