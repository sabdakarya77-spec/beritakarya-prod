# ── Environment Configuration ───────────────────────────────────────────────
NODE_ENV=development

# --- FRONTEND CONFIGURATION (NEXT_PUBLIC_ prefix for browser-side access) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_URL="http://localhost:3000"

# --- ANALYTICS (Optional) ---
NEXT_PUBLIC_GA_ID=""

# --- SITE CONFIGURATION ---
# Uncomment untuk override site default (default: "pusat")
# NEXT_PUBLIC_SITE_ID="pusat"

# ============================================================
# Production (Self-Hosted LXC):
#   NEXT_PUBLIC_API_URL="https://api.beritakarya.co"
#   NEXT_PUBLIC_URL="https://beritakarya.co"
#   NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
#   NEXT_PUBLIC_SITE_ID="pusat"
#
# Lihat apps/api/.env.example.selfhosted untuk backend config
# ============================================================
