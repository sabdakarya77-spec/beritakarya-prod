NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- DATABASE (PostgreSQL) ---
# Local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beritakarya?schema=public&connection_limit=20&connect_timeout=10"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/beritakarya?schema=public"
# Self-hosted production (CT 101): lihat .env.example.selfhosted

# --- REDIS ---
# Kosongkan untuk development lokal (rate limit fallback ke memory)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MEILISEARCH (Opsional) ---
# Kosongkan untuk menonaktifkan Meilisearch (search fallback ke PostgreSQL FTS)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=masterKey

# --- SECURITY ---
JWT_SECRET=your_jwt_secret_64_hex_chars_here
RESET_SECRET=your_password_reset_base64_secret_here
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost

# --- CRON SECURITY ---
# Wajib diisi di produksi. Generate dengan: openssl rand -hex 32
CRON_SECRET=

# --- AI INTEGRATION ---
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# --- EMAIL (SMTP) ---
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS="Redaksi BeritaKarya <redaksi@beritakarya.co>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_gmail_user_here
SMTP_PASS=your_gmail_app_password_here

# --- MinIO Storage (S3-compatible) ---
# BUKAN AWS S3 — ini MinIO lokal (development) atau self-hosted (production)
# Variabel pakai prefix S3_ karena MinIO menggunakan protokol S3 yang sama
# Set 's3' atau 'r2' untuk aktifkan cloud upload (KYC files)
STORAGE_TYPE="s3"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_FORCE_PATH_STYLE=true
S3_BUCKET="kyc"
S3_MEDIA_BUCKET="media"

# Public URL untuk bucket media (akses gambar dari browser)
# Local: http://localhost:9000/media
# Production (Cloudflare CDN): https://media.beritakarya.co
SUPABASE_STORAGE_PUBLIC_URL="http://localhost:9000/media"

# --- ERROR MONITORING ---
SENTRY_DSN=

# --- PAGEVIEW RETENTION ---
PAGEVIEW_RETENTION_DAYS=90

# --- DATABASE SEED ---
SEED_ADMIN_EMAIL=admin@beritakarya.co
SEED_ADMIN_PASSWORD=YourSecurePassword123!
